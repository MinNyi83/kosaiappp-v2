# KosAI Environment Variables
# Copy this file to .dev.vars and fill in your values
# NEVER commit .dev.vars to git!

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Admin
ADMIN_SECRET="your_admin_secret"
ADMIN_EMAIL="your_admin_email"

# Google OAuth (for Drive uploads and sign-in)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REFRESH_TOKEN="your_google_refresh_token"
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# Google Service Account (alternative auth)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your_service_account_email"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="your_private_key"

# JWT - Use a strong random string (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET="your_jwt_secret_min_32_chars"

# CSRF - Use a different secret than JWT
# Generate with: openssl rand -hex 32
CSRF_SECRET="your_csrf_secret_min_32_chars"

# AI
GEMINI_API_KEY="your_gemini_api_key"

# Viber (optional)
VIBER_BOT_TOKEN="your_viber_bot_token"
VIBER_RECEIVER_ID="your_viber_receiver_id"
