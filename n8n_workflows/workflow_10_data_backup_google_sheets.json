    },
    {
      "id": "http-get-inventory",
      "name": "GET /api/inventory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 620],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.KOSAI_BASE_URL }}/api/inventory",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "limit", "value": "1000" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $env.KOSAI_API_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "code-transform-clients",
      "name": "Transform → Clients Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 100],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = Array.isArray(data) ? data : (data.clients || data.data || []);\n\nreturn items.map(c => ({\n  json: {\n    'ID': c.id,\n    'Name': c.name,\n    'Phone': c.phone,\n    'Email': c.email || '',\n    'Address': c.address || '',\n    'Status': c.status || 'active',\n    'Created': c.created_at || c.createdAt || '',\n    'Total Jobs': c.total_jobs || c.job_count || 0,\n    'Total Spent': c.total_spent || 0\n  }\n}));"
      }
    },
    {
      "id": "code-transform-jobs",
      "name": "Transform → Jobs Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 230],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = Array.isArray(data) ? data : (data.jobs || data.data || []);\n\nreturn items.map(j => ({\n  json: {\n    'ID': j.id,\n    'Title': j.title || j.description || '',\n    'Category': j.category || '',\n    'Status': j.status || '',\n    'Client': j.client_name || '',\n    'Worker': j.worker_name || '',\n    'Scheduled': j.scheduled_date || '',\n    'Completed': j.completed_at || j.completedAt || '',\n    'Amount': j.amount || j.total_amount || 0,\n    'Priority': j.priority || 'normal',\n    'Location': j.location || ''\n  }\n}));"
      }
    },
    {
      "id": "code-transform-workers",
      "name": "Transform → Workers Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 360],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = Array.isArray(data) ? data : (data.workers || data.data || []);\n\nreturn items.map(w => ({\n  json: {\n    'ID': w.id,\n    'Name': w.name,\n    'Phone': w.phone || '',\n    'Skills': w.skills || '',\n    'Status': w.status || 'active',\n    'Rating': w.rating || 0,\n    'Current Jobs': w.current_jobs || 0,\n    'Max Jobs': w.max_jobs || 5,\n    'Experience (yrs)': w.experience_years || 0,\n    'Joined': w.created_at || w.createdAt || ''\n  }\n}));"
      }
    },
    {
      "id": "code-transform-invoices",
      "name": "Transform → Invoices Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 490],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = Array.isArray(data) ? data : (data.invoices || data.data || []);\n\nreturn items.map(i => ({\n  json: {\n    'ID': i.id,\n    'Client': i.client_name || '',\n    'Amount': i.total_amount || i.amount || 0,\n    'Status': i.status || '',\n    'Due Date': i.due_date || '',\n    'Paid Amount': i.paid_amount || 0,\n    'Created': i.created_at || i.createdAt || '',\n    'Job ID': i.job_id || ''\n  }\n}));"
      }
    },
    {
      "id": "code-transform-inventory",
      "name": "Transform → Inventory Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 620],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = Array.isArray(data) ? data : (data.items || data.data || []);\n\nreturn items.map(i => ({\n  json: {\n    'ID': i.id,\n    'Name': i.name,\n    'Category': i.category || '',\n    'Quantity': i.quantity || 0,\n    'Min Stock': i.min_stock || 0,\n    'Unit': i.unit || 'pcs',\n    'Unit Price': i.unit_price || 0,\n    'Supplier': i.supplier || '',\n    'Last Restocked': i.last_restocked || ''\n  }\n}));"
      }
    },
    {
      "id": "google-sheets-clients",
      "name": "Google Sheets → Clients",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [850, 100],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Clients",
        "columns": {
          "mappingMode": "defineBelow",
          "value": "={{ $json | toSnakeCase }}"
        },
        "options": {
          "cellFormat": "USER_ENTERED"
        }
      }
    },
    {
      "id": "google-sheets-jobs",
      "name": "Google Sheets → Jobs",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [850, 230],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
