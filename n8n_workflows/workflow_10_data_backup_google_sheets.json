    {
      "id": "telegram-backup-confirm",
      "name": "Telegram → Backup Confirmation",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1050, 375],
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_ADMIN_CHAT_ID }}",
        "text": "💾 *Daily Backup Complete* ✅\\n\\n📊 Google Sheet updated with:\\n• 👥 Clients\\n• 🔧 Jobs\\n• 👷 Workers\\n• 🧾 Invoices\\n• 📦 Inventory\\n\\n🕐 {{ $now.format('YYYY-MM-DD HH:mm') }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      }
    }
  ],
